### 
# @name Test Basic Request
GET https://jsonplaceholder.typicode.com/posts/1
Accept: application/json

> {%
// Check basic response
client.check("Status Code Check", function() {
    return response.body && response.body.id !== undefined;
}, "Response should contain id field");

// Access metrics in check functions (new feature!)
client.check("Response Time Check", function() {
    var httpDuration = client.metrics.getCurrent("http_req_duration");
    console.log("Current request took: " + httpDuration + "ms");
    return httpDuration && httpDuration < 5000; // Should be under 5 seconds
}, "Response time should be under 5 seconds");

// Check aggregated metrics
client.check("Request Count Check", function() {
    var totalReqs = client.metrics.getCurrent("http_reqs");
    console.log("Total requests so far: " + totalReqs);
    return totalReqs && totalReqs > 0;
}, "Should have made at least one request");
%}

### 
# @name Test POST Request
POST https://jsonplaceholder.typicode.com/posts
Content-Type: application/json

{
  "title": "Test Post",
  "body": "This is a test",
  "userId": 1
}

> {%
// Store some data for the next request
client.global.set("testValue", response.body.title);

// Check metrics comparison across requests
client.check("Average Duration Check", function() {
    var metrics = client.metrics.get("http_req_duration");
    if (metrics && metrics.count >= 2) {
        console.log("Average response time: " + metrics.average + "ms");
        console.log("Min response time: " + metrics.min + "ms");
        console.log("Max response time: " + metrics.max + "ms");
        return metrics.average < 3000; // Average should be under 3 seconds
    }
    return true; // Skip if not enough data yet
}, "Average response time should be reasonable");

// Check failure rate
client.check("Success Rate Check", function() {
    var failedRate = client.metrics.get("http_req_failed");
    if (failedRate && failedRate.count > 0) {
        var rate = failedRate.average * 100;
        console.log("Failed request rate: " + rate + "%");
        return rate < 10; // Less than 10% failure rate
    } else {
        console.log("Failed request rate: 0% (no failures recorded)");
        return true; // No failures is good
    }
}, "Failure rate should be low");
%}

### 
# @name Test Multiple Posts
GET https://jsonplaceholder.typicode.com/posts
Accept: application/json

> {%
// Test metrics with large response
client.check("Large Response Check", function() {
    var duration = client.metrics.getCurrent("http_req_duration");
    console.log("Posts request took: " + duration + "ms");
    return duration && duration > 0; // Should have some measurable duration
}, "Posts request should have measurable duration");

// Show all metrics summary  
client.check("Metrics Summary", function() {
    console.log("=== METRICS SUMMARY ===");
    
    // Test individual metric access
    var httpReqs = client.metrics.get("http_reqs");
    var httpDuration = client.metrics.get("http_req_duration");
    var iterations = client.metrics.get("iterations");
    var checks = client.metrics.get("checks");
    
    console.log("HTTP Requests: " + (httpReqs ? httpReqs.count : "N/A"));
    console.log("HTTP Duration: avg=" + (httpDuration ? httpDuration.average.toFixed(1) : "N/A") + "ms, min=" + (httpDuration ? httpDuration.min.toFixed(1) : "N/A") + "ms, max=" + (httpDuration ? httpDuration.max.toFixed(1) : "N/A") + "ms");
    console.log("Iterations: " + (iterations ? iterations.count : "N/A"));
    console.log("Checks: " + (checks ? checks.count : "N/A") + " (success rate: " + (checks ? (checks.average * 100).toFixed(1) : "N/A") + "%)");
    
    return true; // This is just for display
}, "Display metrics summary");
%}

